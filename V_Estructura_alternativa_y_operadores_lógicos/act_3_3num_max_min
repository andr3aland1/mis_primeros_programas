n1 = float(input("Ingrese el primer número: "))
n2 = float(input("Ingrese el segundo número: "))
n3 = float(input("Ingrese el tercer número: "))

# Máximo
if n1 >= n2 and n1 >= n3:
    maximo = n1
elif n2 >= n1 and n2 >= n3:
    maximo = n2
else:
    maximo = n3

# Mínimo
if n1 <= n2 and n1 <= n3:
    minimo = n1
elif n2 <= n1 and n2 <= n3:
    minimo = n2
else:
    minimo = n3

print("Máximo:", maximo)
print("Mínimo:", minimo)